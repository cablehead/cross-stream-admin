# Instance state — per-VM, never published. Materialized at provision/boot time.
# (git .gitignore has no inline comments — keep patterns on their own lines.)

# {tenant, broker, allowlist} — the allowlist is this VM's gate
tenant.json

# the broker's public verify key (fetch from <broker>/pubkey)
broker-pub.jwk

# live sessions + CSRF challenges (runtime)
auth/

# any key material (e.g. pai-sho identity)
*.key

# local backups
*.bak
